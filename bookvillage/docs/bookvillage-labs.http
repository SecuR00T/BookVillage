@baseUrl = http://localhost:8080
@userAuth = Basic dXNlckB5ZXMyNC5tb2NrOnBhc3N3b3Jk
@adminAuth = Basic YWRtaW5AeWVzMjQubW9jazpwYXNzd29yZA==

### Register
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "email": "student2@bookvillage.mock",
  "password": "password123",
  "name": "Student Two"
}

### Login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "user@bookvillage.mock",
  "password": "password"
}

### Find ID
POST {{baseUrl}}/api/auth/find-id
Content-Type: application/json

{
  "name": "Student User",
  "email": "user@bookvillage.mock"
}

### Request password reset
POST {{baseUrl}}/api/auth/password-reset/request
Content-Type: application/json

{
  "email": "user@bookvillage.mock"
}

### Search books
GET {{baseUrl}}/api/books/search?q=java&category=IT

### Book detail
GET {{baseUrl}}/api/books/1
Authorization: {{userAuth}}

### Add cart item
POST {{baseUrl}}/api/cart
Authorization: {{userAuth}}
Content-Type: application/json

{
  "bookId": 1,
  "quantity": 2
}

### Checkout
POST {{baseUrl}}/api/orders/checkout
Authorization: {{userAuth}}
Content-Type: application/json

{
  "items": [
    { "bookId": 1, "quantity": 1 }
  ],
  "paymentMethod": "CARD",
  "couponCode": "WELCOME10",
  "usePoints": 100,
  "shippingAddress": "Seoul"
}

### My orders
GET {{baseUrl}}/api/orders
Authorization: {{userAuth}}

### Guest lookup
GET {{baseUrl}}/api/orders/lookup?orderNumber=ORD-EXAMPLE

### Create inquiry
POST {{baseUrl}}/api/customer-service
Authorization: {{userAuth}}
Content-Type: application/json

{
  "subject": "배송 문의",
  "content": "언제 도착하나요?"
}

### Notices
GET {{baseUrl}}/api/notices

### FAQ
GET {{baseUrl}}/api/faqs

### Mypage wallet
GET {{baseUrl}}/api/mypage/wallet
Authorization: {{userAuth}}

### Link preview
POST {{baseUrl}}/api/integration/link-preview
Authorization: {{userAuth}}
Content-Type: application/json

{
  "url": "https://example.com/book/preview"
}

### Simulate requirement
POST {{baseUrl}}/api/labs/REQ-COM-048/simulate
Authorization: {{userAuth}}
Content-Type: application/json

{
  "input": "metadata endpoint test"
}

### Admin dashboard
GET {{baseUrl}}/api/admin/dashboard
Authorization: {{adminAuth}}

### Admin order status
PUT {{baseUrl}}/api/admin/orders/1/status
Authorization: {{adminAuth}}
Content-Type: application/json

{
  "status": "SHIPPED"
}

### Admin user status
PUT {{baseUrl}}/api/admin/users/2/status
Authorization: {{adminAuth}}
Content-Type: application/json

{
  "status": "SUSPENDED"
}
